@model AnodicaInsumos.Modelos.Proveedor
@using Microsoft.AspNetCore.Mvc.Rendering

@{
    ViewData["Title"] = "Nuevo Proveedor";
    var tipos = ViewBag.TiposProveedor as List<SelectListItem> ?? new();
}

<div class="container py-4">

    <div class="card shadow-sm border-0 mb-3">
        <div class="card-body d-flex align-items-center justify-content-between flex-wrap gap-2">
            <div>
                <h2 class="mb-1 fw-bold">Nuevo Proveedor</h2>
                <div class="text-secondary">Completá los datos para registrar un proveedor.</div>
            </div>

            <a asp-action="Index" class="btn btn-outline-light">
                <i class="bi bi-arrow-left me-1"></i> Volver
            </a>
        </div>
    </div>

    <div class="card shadow-sm border-0">
        <div class="card-body">

            <form asp-action="Create" method="post" class="row g-3">
                @Html.AntiForgeryToken()

                <div asp-validation-summary="ModelOnly" class="text-danger"></div>

                <div class="col-md-6">
                    <label asp-for="ProveedorNombre" class="form-label text-secondary small"></label>
                    <input asp-for="ProveedorNombre" class="form-control" placeholder="Ej: Alejandro Gómez" />
                    <span asp-validation-for="ProveedorNombre" class="text-danger"></span>
                </div>

                <div class="col-md-6">
                    <label asp-for="Telefonos" class="form-label text-secondary small"></label>
                    <input asp-for="Telefonos" class="form-control" placeholder="Ej: (11) 5478-8790" />
                    <span asp-validation-for="Telefonos" class="text-danger"></span>
                </div>

                <div class="col-md-6">
                    <label asp-for="Email" class="form-label text-secondary small"></label>
                    <input asp-for="Email" class="form-control" placeholder="Ej: ejemplo@gmail.com" />
                    <span asp-validation-for="Email" class="text-danger"></span>
                </div>

                <div class="col-md-6">
                    <label asp-for="PorcentajePesoTiraPerfil" class="form-label text-secondary small"></label>
                    <input asp-for="PorcentajePesoTiraPerfil"
                           type="number"
                           step="0.01"
                           min="0"
                           class="form-control"
                           placeholder="Ej: 0.03" />
                    <span asp-validation-for="PorcentajePesoTiraPerfil" class="text-danger"></span>
                </div>

                <div class="col-md-6">
                    <label class="form-label text-secondary small">Categorías del proveedor</label>

                    <select name="tiposSeleccionados"
                            multiple
                            class="form-select">

                        @foreach (var tipo in tipos)
                        {
                            <option value="@tipo.Value">@tipo.Text</option>
                        }
                    </select>

                    <small class="text-secondary">
                        Podés seleccionar múltiples categorías.
                    </small>
                </div>

                <div class="col-12 d-flex gap-2 justify-content-end pt-2">
                    <a asp-action="Index" class="btn btn-outline-secondary">
                        Cancelar
                    </a>
                    <button type="submit" class="btn btn-primary">
                        <i class="bi bi-check2-circle me-1"></i> Guardar
                    </button>
                </div>

            </form>

        </div>
    </div>

</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}