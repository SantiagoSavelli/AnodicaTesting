@model AnodicaInsumos.Modelos.Insumo

@{
    ViewData["Title"] = "Nuevo Insumo";
}

<div class="container py-4">

    <div class="card shadow-sm border-0 mb-3">
        <div class="card-body d-flex align-items-center justify-content-between flex-wrap gap-2">
            <div>
                <h2 class="mb-1 fw-bold">Nuevo Insumo</h2>
                <div class="text-secondary">Completá los datos para registrar un insumo.</div>
            </div>

            <a asp-action="Index" class="btn btn-outline-light">
                <i class="bi bi-arrow-left me-1"></i> Volver
            </a>
        </div>
    </div>

    <div class="card shadow-sm border-0">
        <div class="card-body">

            <form asp-action="Create" method="post" class="row g-3">
                @Html.AntiForgeryToken()

                <div asp-validation-summary="ModelOnly" class="text-danger"></div>

                <div class="col-md-4">
                    <label asp-for="CodigoInsumo" class="form-label text-secondary small"></label>
                    <input asp-for="CodigoInsumo" class="form-control" placeholder="Ej: INS-001" />
                    <span asp-validation-for="CodigoInsumo" class="text-danger"></span>
                </div>

                <div class="col-md-3">
                    <label asp-for="UnidadMedida" class="form-label text-secondary small"></label>
                    <input asp-for="UnidadMedida" class="form-control" placeholder="Ej: UN / KG / M ..." />
                    <span asp-validation-for="UnidadMedida" class="text-danger"></span>
                </div>

                <div class="col-md-2">
                    <label asp-for="CantidadStock" class="form-label text-secondary small"></label>
                    <input asp-for="CantidadStock" class="form-control" placeholder="0" inputmode="decimal" />
                    <span asp-validation-for="CantidadStock" class="text-danger"></span>
                </div>

                <div class="col-md-3">
                    <label asp-for="CantMinimaStock" class="form-label text-secondary small"></label>
                    <input asp-for="CantMinimaStock" class="form-control" placeholder="0" inputmode="decimal" />
                    <span asp-validation-for="CantMinimaStock" class="text-danger"></span>
                </div>

                <div class="col-12">
                    <label asp-for="InsumoNombre" class="form-label text-secondary small"></label>
                    <input asp-for="InsumoNombre" class="form-control" placeholder="Ej: Ácido Nítrico 65%" />
                    <span asp-validation-for="InsumoNombre" class="text-danger"></span>
                </div>

                <div class="col-12 d-flex gap-2 justify-content-end pt-2">
                    <a asp-action="Index" class="btn btn-outline-secondary">
                        Cancelar
                    </a>
                    <button type="submit" class="btn btn-primary">
                        <i class="bi bi-check2-circle me-1"></i> Guardar
                    </button>
                </div>

            </form>

        </div>
    </div>

</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}