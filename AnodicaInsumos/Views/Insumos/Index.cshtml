@{
    ViewData["Title"] = "Lista de Insumos";
}

<div class="container py-4">
    <div class="d-flex align-items-center justify-content-between flex-wrap gap-3">
        <div class="d-flex align-items-center gap-3">
            <div>
                <h2 class="mb-0">Insumos</h2>
                <small class="text-muted">Administrá el stock y unidades de medida</small>
            </div>
        </div>

        <a asp-action="Create" class="btn btn-primary">
            <i class="bi bi-plus-lg me-1"></i> Nuevo insumo
        </a>
    </div>

    <div class="card bg-dark text-light shadow border-0">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table id="tblInsumos" class="table table-dark table-hover align-middle mb-0">
                    <thead class="border-bottom border-secondary">
                        <tr class="text-uppercase small text-secondary">
                            <th class="ps-3">Código</th>
                            <th>Nombre</th>
                            <th class="text-center">Unidad de Medida</th>
                            <th class="text-end pe-3">Acciones</th>
                        </tr>
                        
                        <tr>
                            <th class="ps-3">
                                <input id="fCodigo" class="form-control form-control-sm bg-dark text-light border-secondary"
                                       placeholder="Filtrar código..." />
                            </th>
                            <th>
                                <input id="fNombre" class="form-control form-control-sm bg-dark text-light border-secondary"
                                       placeholder="Filtrar nombre..." />
                            </th>
                            <th class="text-center">
                                <input id="fUnidad" class="form-control form-control-sm bg-dark text-light border-secondary text-center"
                                       placeholder="UN / KG / LT..." />
                            </th>
                            <th class="text-end pe-3">
                                <button id="btnLimpiar" class="btn btn-sm btn-outline-secondary">
                                    <i class="bi bi-x-lg me-1"></i> Limpiar
                                </button>
                            </th>
                        </tr>
                    </thead>
                    <tbody></tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="modalEliminar" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content bg-dark text-light border border-secondary">
            <div class="modal-header border-secondary">
                <h5 class="modal-title">
                    <i class="bi bi-exclamation-triangle text-warning me-2"></i>
                    Confirmar eliminación
                </h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>

            <div class="modal-body">
                ¿Seguro que querés eliminar este insumo?
                <div id="modalEliminarDetalle" class="small text-secondary mt-2"></div>
            </div>

            <div class="modal-footer border-secondary">
                <button type="button" class="btn btn-outline-light" data-bs-dismiss="modal">
                    Cancelar
                </button>
                <button type="button" class="btn btn-danger" id="btnConfirmarEliminar">
                    <i class="bi bi-trash me-1"></i> Eliminar
                </button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/js/insumos.js"></script>
}