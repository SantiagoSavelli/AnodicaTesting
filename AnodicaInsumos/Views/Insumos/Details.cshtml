@model AnodicaInsumos.Modelos.Insumo

@{
    ViewData["Title"] = "Detalle del Insumo";
}

<div class="container py-4">

    <div class="card shadow-sm border-0 mb-3">
        <div class="card-body d-flex align-items-center justify-content-between flex-wrap gap-2">
            <div>
                <h2 class="mb-1 fw-bold">Detalle del Insumo</h2>
                <div class="text-secondary">Información completa del registro.</div>
            </div>

            <div class="d-flex gap-2">
                <a asp-action="Index" class="btn btn-outline-light">
                    <i class="bi bi-arrow-left me-1"></i> Volver
                </a>
                <a asp-action="Edit" asp-route-id="@Model.InsumoID" class="btn btn-warning">
                    <i class="bi bi-pencil me-1"></i> Editar
                </a>
            </div>
        </div>
    </div>

    <div class="card bg-dark text-light shadow border-0">
        <div class="card-body">
            <div class="row g-3">

                <div class="col-md-4">
                    <div class="text-secondary small">Código</div>
                    <div class="fw-semibold">@Model.CodigoInsumo</div>
                </div>

                <div class="col-md-8">
                    <div class="text-secondary small">Nombre</div>
                    <div class="fw-semibold">@Model.InsumoNombre</div>
                </div>

                <div class="col-md-4">
                    <div class="text-secondary small">Unidad de medida</div>
                    <span class="fw-semibold">@Model.UnidadMedida</span>
                </div>

                <div class="col-md-4">
                    <div class="text-secondary small">Stock</div>
                    <div class="fw-semibold">@Model.CantidadStock</div>
                </div>

                <div class="col-md-4">
                    <div class="text-secondary small">Stock mínimo</div>
                    <div class="fw-semibold">@Model.CantMinimaStock</div>
                </div>

            </div>
        </div>
    </div>

</div>