@model AnodicaInsumos.Modelos.ViewModels.PerfilVM
@using AnodicaInsumos.Modelos
@using AnodicaInsumos.Modelos.ViewModels
@using Microsoft.AspNetCore.Mvc.Rendering

@{
    ViewData["Title"] = "Nuevo Perfil";

    var proveedores = Model.Proveedores ?? new List<SelectListItem>();
    var lineas = Model.Lineas ?? new List<SelectListItem>();
    var ubicaciones = Model.Ubicaciones ?? new List<SelectListItem>();
    var tratamientos = Model.Tratamientos ?? new List<SelectListItem>();
    var perfilTratamientos = Model.PerfilTratamientos ?? new List<PerfilTratamientoVM>();
    var perfilEquivalencias = Model.PerfilEquivalencias ?? new List<PerfilEquivalenciaVM>();
}

<div class="container py-4">

    <div class="card shadow-sm border-0 mb-3">
        <div class="card-body d-flex align-items-center justify-content-between flex-wrap gap-2">
            <div>
                <h2 class="mb-1 fw-bold">Nuevo Perfil</h2>
                <div class="text-secondary">Completá los datos generales, imagen y stock mínimo por tratamiento.</div>
            </div>

            <a asp-action="Index" class="btn btn-outline-light">
                <i class="bi bi-arrow-left me-1"></i> Volver
            </a>
        </div>
    </div>

    <form asp-action="Create" method="post" enctype="multipart/form-data">
        @Html.AntiForgeryToken()

        <div asp-validation-summary="All" class="text-danger mb-3"></div>

        <div class="card shadow-sm border-0 mb-4">
            <div class="card-body">
                <h4 class="fw-bold mb-3">Datos generales</h4>

                <div class="row g-3">

                    <div class="col-md-3">
                        <label asp-for="Perfil.PerfilCodigoAlcemar" class="form-label text-secondary small">Código</label>
                        <input asp-for="Perfil.PerfilCodigoAlcemar" class="form-control" placeholder="Ej: 101" />
                        <span asp-validation-for="Perfil.PerfilCodigoAlcemar" class="text-danger"></span>
                    </div>

                    <div class="col-md-4">
                        <label class="form-label text-secondary small">Proveedor</label>
                        <select id="ProveedorFiltro" class="form-select">
                            <option value="">Seleccionar proveedor...</option>
                            @foreach (var item in proveedores)
                            {
                                <option value="@item.Value">@item.Text</option>
                            }
                        </select>
                    </div>

                    <div class="col-md-5">
                        <label asp-for="Perfil.LineaRef" class="form-label text-secondary small">Línea</label>
                        <select asp-for="Perfil.LineaRef" asp-items="lineas" class="form-select" id="LineaRef">
                            <option value="">Seleccionar línea...</option>
                        </select>
                        <span asp-validation-for="Perfil.LineaRef" class="text-danger"></span>
                    </div>

                    <div class="col-12">
                        <label asp-for="Perfil.Descripcion" class="form-label text-secondary small"></label>
                        <input asp-for="Perfil.Descripcion" class="form-control" placeholder="Ej: MARCO CORREDIZA - LINEA LIVIANA" />
                        <span asp-validation-for="Perfil.Descripcion" class="text-danger"></span>
                    </div>

                    <div class="col-md-6">
                        <label asp-for="ArchivoImagen" class="form-label text-secondary small">Forma</label>
                        <input asp-for="ArchivoImagen" type="file" id="archivoImagen" class="form-control" accept="image/*" />
                        <small class="text-secondary">Podés cargar una imagen del perfil.</small>
                        <span asp-validation-for="ArchivoImagen" class="text-danger"></span>
                    </div>

                    <div class="col-md-6">
                        <label class="form-label text-secondary small d-block">Vista previa</label>
                        <div class="border border-secondary rounded bg-dark-subtle d-flex align-items-center justify-content-center"
                             style="height:110px;">
                            <img id="previewImagen"
                                 src="https://placehold.co/100x70?text=Sin+imagen"
                                 alt="Vista previa"
                                 style="max-height:90px; max-width:100%; object-fit:contain;" />
                        </div>
                    </div>

                    <div class="col-md-3">
                        <label asp-for="Perfil.PesoXmetro" class="form-label text-secondary small">Peso/metro</label>
                        <input asp-for="Perfil.PesoXmetro" type="number" step="0.01" min="0" class="form-control" id="PesoXmetro" />
                        <span asp-validation-for="Perfil.PesoXmetro" class="text-danger"></span>
                    </div>

                    <div class="col-md-3">
                        <label asp-for="Perfil.LongTiraMts" class="form-label text-secondary small">Mts longitud tira</label>
                        <input asp-for="Perfil.LongTiraMts" type="number" step="0.01" min="0" class="form-control" id="LongTiraMts" />
                        <span asp-validation-for="Perfil.LongTiraMts" class="text-danger"></span>
                    </div>

                    <div class="col-md-3">
                        <label asp-for="Perfil.CantTirasPaquete" class="form-label text-secondary small">Tiras/paquete</label>
                        <input asp-for="Perfil.CantTirasPaquete" type="number" min="0" class="form-control" />
                        <span asp-validation-for="Perfil.CantTirasPaquete" class="text-danger"></span>
                    </div>

                    <div class="col-md-3 d-flex align-items-end">
                        <div class="form-check form-switch">
                            <input asp-for="Perfil.ManejaStockPropio" class="form-check-input" />
                            <label asp-for="Perfil.ManejaStockPropio" class="form-check-label"></label>
                        </div>
                    </div>

                    <div class="col-md-3">
                        <label asp-for="Perfil.PesoXtira" class="form-label text-secondary small">Peso/tira</label>
                        <input asp-for="Perfil.PesoXtira" type="number" step="0.01" min="0" class="form-control" />
                        <span asp-validation-for="Perfil.PesoXtira" class="text-danger"></span>
                    </div>
                </div>
            </div>
        </div>

        <div class="card shadow-sm border-0 mb-4">
            <div class="card-body">
                <h4 class="fw-bold mb-3">Ubicación y Stock Mínimo por Tratamiento</h4>

                <div class="table-responsive">
                    <table class="table table-dark table-hover align-middle mb-0">
                        <thead class="border-bottom border-secondary">
                            <tr class="text-uppercase small text-secondary">
                                <th>Tratamiento</th>
                                <th>Ubicación</th>
                                <th>Stock mínimo</th>
                            </tr>
                        </thead>

                        <tbody>
                            @for (int i = 0; i < Model.PerfilTratamientos.Count; i++)
                            {

                                <tr>
                                    <td>
                                        @Model.PerfilTratamientos[i].Descripcion

                                        <input type="hidden" asp-for="PerfilTratamientos[i].TratamientoRef" />
                                        <input type="hidden" asp-for="PerfilTratamientos[i].Descripcion" />
                                    </td>

                                    <td>
                                        <select asp-items="Model.Ubicaciones" asp-for="PerfilTratamientos[i].UbicacionRef" class="form-select form-select-sm">
                                            <option value="">Sin ubicación</option>
                                        </select>
                                    </td>

                                    <td>
                                        <input asp-for="PerfilTratamientos[i].CantMinimaTirasStock" type="number" min="0" class="form-control form-control-sm" />

                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

        <div class="card shadow-sm border-0 mb-4">
            <div class="card-body">

                <h4 class="fw-bold mb-3">Equivalencias</h4>

                <div class="table-responsive">
                    <table class="table table-dark table-hover align-middle mb-0">
                        <thead class="border-bottom border-secondary">
                            <tr class="text-uppercase small text-secondary">
                                <th style="width:200px;">Código</th>
                                <th>Descripción perfil equivalente</th>
                                <th style="width:60px;"></th>
                            </tr>
                        </thead>

                        <tbody id="tablaEquivalencias">
                            @if (Model.PerfilEquivalencias != null && Model.PerfilEquivalencias.Any())
                            {
                                for (int i = 0; i < Model.PerfilEquivalencias.Count; i++)
                                {
                                    <tr>
                                        <td>
                                            <input asp-for="PerfilEquivalencias[i].Codigo"
                                                   class="form-control form-control-sm codigoEquivalente"
                                                   placeholder="Código perfil" />

                                            <input asp-for="PerfilEquivalencias[i].PerfilEquivalenteRef" type="hidden" />
                                        </td>

                                        <td>
                                            <input asp-for="PerfilEquivalencias[i].Descripcion"
                                                   class="form-control form-control-sm descripcionEquivalente"
                                                   readonly />
                                        </td>

                                        <td class="text-center">
                                            @if (i == 0)
                                            {
                                                <button type="button"
                                                        class="btn btn-success btn-sm"
                                                        onclick="agregarEquivalencia()">
                                                    <i class="bi bi-plus-lg"></i>
                                                </button>
                                            }
                                            else
                                            {
                                                <button type="button"
                                                        class="btn btn-danger btn-sm"
                                                        onclick="eliminarFila(this)">
                                                    <i class="bi bi-x-lg"></i>
                                                </button>
                                            }
                                        </td>
                                    </tr>
                                }
                            }
                            else
                            {
                                <tr>
                                    <td>
                                        <input name="PerfilEquivalencias[0].Codigo"
                                               class="form-control form-control-sm codigoEquivalente"
                                               placeholder="Código perfil" />

                                        <input name="PerfilEquivalencias[0].PerfilEquivalenteRef"
                                               type="hidden"
                                               value="" />
                                    </td>

                                    <td>
                                        <input name="PerfilEquivalencias[0].Descripcion"
                                               class="form-control form-control-sm descripcionEquivalente"
                                               readonly />
                                    </td>

                                    <td class="text-center">
                                        <button type="button"
                                                class="btn btn-success btn-sm"
                                                onclick="agregarEquivalencia()">
                                            <i class="bi bi-plus-lg"></i>
                                        </button>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

        <div class="d-flex gap-2 justify-content-end">
            <a asp-action="Index" class="btn btn-outline-secondary">
                Cancelar
            </a>

            <button type="submit" class="btn btn-primary">
                <i class="bi bi-check2-circle me-1"></i> Guardar
            </button>
        </div>

    </form>

</div>

@section Scripts {

    <partial name="_ValidationScriptsPartial" />

    <script>
        document.getElementById("archivoImagen")?.addEventListener("change", function (e) {
            const file = e.target.files[0];
            if (!file) return;

            const reader = new FileReader();

            reader.onload = function (ev) {
                document.getElementById("previewImagen").src = ev.target.result;
            };

            reader.readAsDataURL(file);
        });

        document.getElementById("ProveedorFiltro")?.addEventListener("change", async function () {
            const proveedorId = this.value;
            const lineaSelect = document.getElementById("LineaRef");

            lineaSelect.innerHTML = `<option value="">Seleccionar línea...</option>`;

            if (!proveedorId) return;

            try {
                const resp = await fetch(`/Perfiles/GetLineasPorProveedor?proveedorId=${proveedorId}`);
                const data = await resp.json();

                data.forEach(linea => {
                    const option = document.createElement("option");
                    option.value = linea.value;
                    option.textContent = linea.text;
                    lineaSelect.appendChild(option);
                });

            } catch (e) {
                console.error("Error cargando líneas", e);
            }
        });

        document.addEventListener("input", async function (e) {
            if (!e.target.classList.contains("codigoEquivalente"))
                return;

            const codigo = e.target.value;
            const fila = e.target.closest("tr");
            const descripcionInput = fila.querySelector(".descripcionEquivalente");

            if (!codigo) {
                descripcionInput.value = "";
                return;
            }

            try {
                const resp = await fetch(`/Perfiles/GetPerfilPorCodigo?codigo=${codigo}`);
                const data = await resp.json();

                if (data) {
                    descripcionInput.value = data.descripcion;
                } else {
                    descripcionInput.value = "Perfil no encontrado";
                }

            } catch (error) {
                console.error(error);
            }
        });

        function agregarEquivalencia() {
            const tabla = document.getElementById("tablaEquivalencias");
            const index = tabla.querySelectorAll("tr").length;

            const fila = document.createElement("tr");

            fila.innerHTML = `
                <td>
                    <input name="PerfilEquivalencias[${index}].Codigo"
                           class="form-control form-control-sm codigoEquivalente"
                           placeholder="Código perfil" />

                    <input name="PerfilEquivalencias[${index}].PerfilEquivalenteRef"
                           type="hidden"
                           value="" />
                </td>

                <td>
                    <input name="PerfilEquivalencias[${index}].Descripcion"
                           class="form-control form-control-sm descripcionEquivalente"
                           readonly />
                </td>

                <td class="text-center">
                    <button type="button"
                            class="btn btn-danger btn-sm"
                            onclick="eliminarFila(this)">
                        <i class="bi bi-x-lg"></i>
                    </button>
                </td>
            `;

            tabla.appendChild(fila);
        }

        function eliminarFila(btn) {
            btn.closest("tr").remove();
            reindexarEquivalencias();
        }

        function reindexarEquivalencias() {
            const filas = document.querySelectorAll("#tablaEquivalencias tr");

            filas.forEach((fila, index) => {
                fila.querySelectorAll("input").forEach(input => {
                    if (input.name.includes(".Codigo")) {
                        input.name = `PerfilEquivalencias[${index}].Codigo`;
                    }
                    if (input.name.includes(".Descripcion")) {
                        input.name = `PerfilEquivalencias[${index}].Descripcion`;
                    }
                    if (input.name.includes(".PerfilEquivalenteRef")) {
                        input.name = `PerfilEquivalencias[${index}].PerfilEquivalenteRef`;
                    }
                });
            });
        }
    </script>
}