@{
    ViewData["Title"] = "Lista de Perfiles";
}

<div class="container py-4">
    <div class="d-flex align-items-center justify-content-between flex-wrap gap-3">
        <div class="d-flex align-items-center gap-3">
            <div>
                <h2 class="mb-0">Perfiles</h2>
                <small class="text-muted">Administrá los perfiles, líneas y proveedores.</small>
            </div>
        </div>

        <a asp-action="Create" class="btn btn-primary">
            <i class="bi bi-plus-lg me-1"></i> Nuevo perfil
        </a>
    </div>

    <div class="card bg-dark text-light shadow border-0 mt-3">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table id="tblPerfiles" class="table table-dark table-hover align-middle mb-0">
                    <thead class="border-bottom border-secondary">
                        <tr class="text-uppercase small text-secondary">
                            <th class="ps-3" style="min-width: 120px;">Código</th>
                            <th style="min-width: 180px;">Proveedor</th>
                            <th style="min-width: 180px;">Línea</th>
                            <th style="min-width: 320px;">Descripción</th>
                            <th class="text-center" style="min-width: 160px;">Forma</th>
                            <th class="text-end pe-3" style="min-width: 160px;">Acciones</th>
                        </tr>

                        <tr>
                            <th class="ps-3">
                                <input id="fCodigo" class="form-control form-control-sm bg-dark text-light border-secondary"
                                       placeholder="Filtrar código..." />
                            </th>
                            <th>
                                <input id="fProveedor" class="form-control form-control-sm bg-dark text-light border-secondary"
                                       placeholder="Filtrar proveedor..." />
                            </th>
                            <th>
                                <input id="fLinea" class="form-control form-control-sm bg-dark text-light border-secondary"
                                       placeholder="Filtrar línea..." />
                            </th>
                            <th>
                                <input id="fDescripcion" class="form-control form-control-sm bg-dark text-light border-secondary"
                                       placeholder="Filtrar descripción..." />
                            </th>
                            <th class="text-center text-secondary small">
                                Vista previa
                            </th>
                            <th class="text-end pe-3">
                                <button id="btnLimpiar" class="btn btn-sm btn-outline-secondary">
                                    <i class="bi bi-x-lg me-1"></i> Limpiar
                                </button>
                            </th>
                        </tr>
                    </thead>
                    <tbody></tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<div class="d-flex justify-content-between align-items-center mt-3">
    <div class="small text-secondary" id="paginacionInfo"></div>
    <nav>
        <ul class="pagination pagination-sm mb-0" id="paginacion"></ul>
    </nav>
</div>

<div class="modal fade" id="modalEliminar" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content bg-dark text-light border border-secondary">
            <div class="modal-header border-secondary">
                <h5 class="modal-title">
                    <i class="bi bi-exclamation-triangle text-warning me-2"></i>
                    Confirmar eliminación
                </h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>

            <div class="modal-body">
                ¿Seguro que querés eliminar este perfil?
                <div id="modalEliminarDetalle" class="small text-secondary mt-2"></div>
            </div>

            <div class="modal-footer border-secondary">
                <button type="button" class="btn btn-outline-light" data-bs-dismiss="modal">
                    Cancelar
                </button>
                <button type="button" class="btn btn-danger" id="btnConfirmarEliminar">
                    <i class="bi bi-trash me-1"></i> Eliminar
                </button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/js/perfiles.js"></script>
}