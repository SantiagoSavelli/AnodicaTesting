@model AnodicaInsumos.Modelos.ViewModels.PerfilVM
@using AnodicaInsumos.Modelos.ViewModels
@using AnodicaInsumos.Modelos

@{
    ViewData["Title"] = "Detalle de Perfil";

    var perfilTratamientos = Model.PerfilTratamientos ?? new List<PerfilTratamientoVM>();
    var perfilEquivalencias = Model.PerfilEquivalencias ?? new List<PerfilEquivalenciaVM>();
}

<div class="container py-4">

    <div class="card shadow-sm border-0 mb-3">
        <div class="card-body d-flex align-items-center justify-content-between flex-wrap gap-2">
            <div>
                <h2 class="mb-1 fw-bold">Detalle de Perfil</h2>
                <div class="text-secondary">Consultá la información completa del perfil.</div>
            </div>

            <div class="d-flex gap-2">
                <a asp-action="Edit" asp-route-id="@Model.Perfil.PerfilID" class="btn btn-warning">
                    <i class="bi bi-pencil me-1"></i> Editar
                </a>
                <a asp-action="Index" class="btn btn-outline-light">
                    <i class="bi bi-arrow-left me-1"></i> Volver
                </a>
            </div>
        </div>
    </div>

    <div class="card shadow-sm border-0 mb-4">
        <div class="card-body">
            <h4 class="fw-bold mb-3">Datos generales</h4>

            <div class="row g-3">

                <div class="col-md-3">
                    <label class="form-label text-secondary small">Código</label>
                    <input class="form-control" value="@Model.Perfil.PerfilCodigoAlcemar" readonly />
                </div>

                <div class="col-md-4">
                    <label class="form-label text-secondary small">Proveedor</label>
                    <input class="form-control" value="@(Model.Perfil.Linea?.Proveedor?.ProveedorNombre ?? "")" readonly />
                </div>

                <div class="col-md-5">
                    <label class="form-label text-secondary small">Línea</label>
                    <input class="form-control" value="@(Model.Perfil.Linea?.LineaNombre ?? "")" readonly />
                </div>

                <div class="col-12">
                    <label class="form-label text-secondary small">Descripción</label>
                    <input class="form-control" value="@Model.Perfil.Descripcion" readonly />
                </div>

                <div class="col-md-6">
                    <label class="form-label text-secondary small">Forma</label>
                    <div class="border border-secondary rounded bg-dark-subtle d-flex align-items-center justify-content-center"
                         style="height: 140px;">
                        @if (Model.Perfil.ImagenPerfil != null && Model.Perfil.ImagenPerfil.Length > 0)
                        {
                            <img src="data:image/png;base64,@Convert.ToBase64String(Model.Perfil.ImagenPerfil)"
                                 alt="Forma del perfil"
                                 style="max-height: 120px; max-width: 100%; object-fit: contain;" />
                        }
                        else
                        {
                            <span class="text-secondary">Sin imagen</span>
                        }
                    </div>
                </div>

                <div class="col-md-3">
                    <label class="form-label text-secondary small">Peso/metro</label>
                    <input class="form-control" value="@Model.Perfil.PesoXmetro.ToString("0.00")" readonly />
                </div>

                <div class="col-md-3">
                    <label class="form-label text-secondary small">Mts longitud tira</label>
                    <input class="form-control" value="@Model.Perfil.LongTiraMts.ToString("0.00")" readonly />
                </div>

                <div class="col-md-3">
                    <label class="form-label text-secondary small">Peso/tira</label>
                    <input class="form-control" value="@(Model.Perfil.PesoXtira?.ToString("0.00") ?? "")" readonly />
                </div>

                <div class="col-md-3">
                    <label class="form-label text-secondary small">Tiras/paquete</label>
                    <input class="form-control" value="@Model.Perfil.CantTirasPaquete" readonly />
                </div>

                <div class="col-md-3">
                    <label class="form-label text-secondary small">Maneja stock propio</label>
                    <input class="form-control" value="@(Model.Perfil.ManejaStockPropio ? "Sí" : "No")" readonly />
                </div>
            </div>
        </div>
    </div>
</div>